        "import pandas as pd\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "# use pandas.get_dummies for categorical, then StandardScaler for numeric.\n",
        "\n",
        "# combines all the features into one data froame so that all the categories will show in all the datasets\n",
        "X_combined = pd.concat([X_train, X_val, X_test], axis=0, ignore_index=True)\n",
        "\n",
        "# 3.1 One-hot encode (fit on full combined X to keep columns aligned)\n",
        "X_full_encoded = pd.get_dummies(X_combined, drop_first=True)\n",
        "\n",
        "# Re-split encoded data since indices are now common\n",
        "train_size = X_train.shape[0]\n",
        "val_size   = X_val.shape[0]\n",
        "test_size  = X_test.shape[0]\n",
        "#iloc is used to move the encoded data back into its original sets using row positions to ensure data accuracy and data leakage.\n",
        "#helps with skewed and imbalanced data\n",
        "X_train_enc = X_full_encoded.iloc[:train_size]\n",
        "X_val_enc   = X_full_encoded.iloc[train_size : train_size + val_size]\n",
        "X_test_enc  = X_full_encoded.iloc[train_size + val_size : ]\n",
        "\n",
        "# Scale numeric features\n",
        "# This is because logstic regression and MLP are sensitive to scale and that all the datasets are applied the same transformation.\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train_enc)\n",
        "X_val_scaled   = scaler.transform(X_val_enc)\n",
        "X_test_scaled  = scaler.transform(X_test_enc)\n",
        "\n",
        "#keep as numpy arrays to work better for mlp\n",
        "X_train_np = X_train_scaled\n",
