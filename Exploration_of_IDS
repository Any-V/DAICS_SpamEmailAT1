    {
      "cell_type": "code",
      "source": [
        "input_dim = X_train_np.shape[1]\n",
        "\n",
        "def build_mlp(input_dim, num_classes):\n",
        "    model = keras.Sequential([\n",
        "        layers.Input(shape=(input_dim,)),\n",
        "        layers.Dense(128, activation=\"relu\"),\n",
        "        layers.Dense(64, activation=\"relu\"),\n",
        "        layers.Dense(num_classes, activation=\"softmax\")\n",
        "    ])\n",
        "    model.compile(\n",
        "        optimizer=keras.optimizers.Adam(learning_rate=0.001),\n",
        "        loss=\"categorical_crossentropy\",\n",
        "        metrics=[\"accuracy\"]\n",
        "    )\n",
        "    return model\n",
        "# adam is a model that is used to make the process faster by changing the learning rate depending on how the model is currently processing the data.\n",
        "#This is helpful because this handles noisy data like an IDS.\n",
        "mlp = build_mlp(input_dim, num_classes)\n",
        "#EarlyStopping is used to make sure that the model doesn't overfit the data and stops exactly when it's reached the max accuracy it can.\n",
        "early_stopping = keras.callbacks.EarlyStopping(\n",
        "    monitor=\"val_loss\",\n",
        "    patience=5,\n",
        "    restore_best_weights=True\n",
        ")\n",
        "\n",
        "history = mlp.fit(\n",
        "    X_train_np, y_train_cat,\n",
        "    validation_data=(X_val_np, y_val_cat),\n",
        "    epochs=50,\n",
        "    batch_size=64,\n",
        "    callbacks=[early_stopping],\n",
        "    verbose=1\n",
        ")\n",
        "\n",
        "# Evaluate on validation and test\n",
        "val_loss, val_acc = mlp.evaluate(X_val_np, y_val_cat, verbose=0)\n",
        "test_loss, test_acc = mlp.evaluate(X_test_np, y_test_cat, verbose=0)\n",
        "\n",
        "print(\"\\n=== MLP – Validation ===\")\n",
        "print(\"Accuracy:\", val_acc)\n",
        "\n",
        "print(\"\\n=== MLP – Test ===\")\n",
        "print(\"Accuracy:\", test_acc)\n",
        "\n",
        "# Predictions for classification report\n",
        "y_val_pred_mlp  = np.argmax(mlp.predict(X_val_np), axis=1)\n",
        "y_test_pred_mlp = np.argmax(mlp.predict(X_test_np), axis=1)\n",
        "\n",
        "print(\"\\n=== MLP – Validation Classification Report ===\")\n",
        "print(classification_report(y_val_enc, y_val_pred_mlp, target_names=label_encoder.classes_))\n",
        "\n",
        "print(\"\\n=== MLP – Test Classification Report ===\")\n",
        "print(classification_report(y_test_enc, y_test_pred_mlp, target_names=label_encoder.classes_))\n"
      ],
