        "    report = classification_report(y_true, y_pred, output_dict=True)\n",
        "    macro_f1 = report[\"macro avg\"][\"f1-score\"]\n",
        "    results.append({\n",
        "        \"Model\": name,\n",
        "        \"Accuracy\": acc,\n",
        "        \"Macro F1\": macro_f1\n",
        "    })\n",
        "\n",
        "add_result(\"Logistic Regression\", y_test_enc, y_test_pred_lr)\n",
